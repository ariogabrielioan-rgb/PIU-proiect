<Window x:Class="Interface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Interface"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <Label x:Name="lblId" Content="ID va apărea aici" FontSize="14" FontWeight="Bold"/>

            <TextBlock x:Name="txtTextIntrebare" Text="Textul întrebării" TextWrapping="Wrap" Margin="0,10" FontSize="16"/>

            <Label x:Name="lblDificultate" Content="Dificultate" FontStyle="Italic"/>
        </StackPanel>
    </Grid>
</Window>
