<Window x:Class="Interface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quiz Game" Height="500" Width="450">
    <Grid Margin="20">
        <StackPanel x:Name="pnlMeniu" VerticalAlignment="Center">
            <Button Content="ADĂUGARE ÎNTREBARE" Click="BtnNavAdaugare_Click" Margin="0,10" Height="50" Background="#E3F2FD"/>
            <Button Content="PREIA TEST" Click="BtnNavQuiz_Click" Margin="0,10" Height="50" Background="#E8F5E9"/>
        </StackPanel>

        <StackPanel x:Name="pnlAdaugare" Visibility="Collapsed">
            <Button Content="← Înapoi" Click="BtnBack_Click" HorizontalAlignment="Left" Margin="0,0,0,10"/>

            <Label Content="Text Întrebare:"/>
            <TextBox x:Name="txtAddText" Margin="0,5"/>

            <Label Content="Răspuns Corect:"/>
            <TextBox x:Name="txtAddRaspuns" Margin="0,5"/>

            <Label Content="Punctaj:"/>
            <TextBox x:Name="txtAddPunctaj" Margin="0,5"/>

            <Label Content="Dificultate:"/>
            <ComboBox x:Name="cmbDificultate" Margin="0,5">
                <ComboBoxItem Content="Ușor" IsSelected="True"/>
                <ComboBoxItem Content="Mediu"/>
                <ComboBoxItem Content="Greu"/>
            </ComboBox>

            <Button Content="Salvează Întrebarea" Click="BtnSalveazaIntrebare_Click" Margin="0,20" Padding="10" Background="#C8E6C9"/>
        </StackPanel>

        <StackPanel x:Name="pnlQuiz" Visibility="Collapsed">
            <Button Content="← Abandon" Click="BtnBack_Click" HorizontalAlignment="Left" Margin="0,0,0,10"/>

            <Label x:Name="lblId" FontSize="14" FontWeight="Bold"/>
            <TextBlock x:Name="txtTextIntrebare" FontSize="16" TextWrapping="Wrap" Margin="0,10"/>
            <Label x:Name="lblDificultate" FontStyle="Italic"/>

            <Label Content="Răspunsul tău:" Margin="0,10,0,0"/>
            <TextBox x:Name="txtRaspunsUtilizator" Margin="0,5" Padding="5"/>

            <Button x:Name="btnNext" Content="Trimite Răspuns" Click="btnNext_Click" Margin="0,10" Padding="10"/>
            <Label x:Name="lblFeedback" HorizontalAlignment="Center" FontWeight="Bold"/>
            <Label x:Name="lblScorLive" Content="Scor: 0" HorizontalAlignment="Right" FontWeight="Bold" Foreground="Blue"/>
        </StackPanel>
    </Grid>
</Window>