<Window x:Class="Interface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestiune Test" Height="650" Width="600" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">

        <StackPanel x:Name="pnlMeniu" VerticalAlignment="Center">
            <Label Content="MENIU PRINCIPAL" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <Label Content="Caută scor după nume:"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBox x:Name="txtCautareNume" Width="430" Padding="5"/>
                <Button Content="Caută" Click="BtnCautare_Click" Width="100" Margin="10,0,0,0" Background="#FFF9C4"/>
            </StackPanel>

            <Button Content="ADĂUGARE ÎNTREBARE" Click="BtnNavAdaugare_Click" Margin="0,10" Height="50" Background="#E3F2FD" Cursor="Hand"/>
            <Button Content="PREIA TEST" Click="BtnNavQuiz_Click" Margin="0,10" Height="50" Background="#E8F5E9" Cursor="Hand"/>

            <Button Content="VEZI TOATE REZULTATELE" Click="BtnVeziRezultate_Click" Margin="0,10" Height="40" Background="#F5F5F5"/>
        </StackPanel>

        <StackPanel x:Name="pnlAdaugare" Visibility="Collapsed">
            <Button Content="← Înapoi" Click="BtnBack_Click" HorizontalAlignment="Left" Margin="0,0,0,10" Background="Transparent"/>

            <Label x:Name="lblLgText" Content="Text Întrebare:"/>
            <TextBox x:Name="txtAddText" Margin="0,5" Padding="3"/>

            <Label Content="Variante (bifează variantele corecte):" FontWeight="Bold" Margin="0,10,0,5"/>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtAddVarA" Grid.Column="0" Padding="3"/>
                <CheckBox x:Name="chkAddA" Grid.Column="1" Content="Corect" Margin="5,0,0,0" VerticalAlignment="Center"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtAddVarB" Grid.Column="0" Padding="3"/>
                <CheckBox x:Name="chkAddB" Grid.Column="1" Content="Corect" Margin="5,0,0,0" VerticalAlignment="Center"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtAddVarC" Grid.Column="0" Padding="3"/>
                <CheckBox x:Name="chkAddC" Grid.Column="1" Content="Corect" Margin="5,0,0,0" VerticalAlignment="Center"/>
            </Grid>

            <Label Content="Punctaj (1-100):" Margin="0,10,0,0"/>
            <TextBox x:Name="txtAddPunctaj" Margin="0,5" Padding="3"/>

            <Label Content="Dificultate:"/>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <RadioButton x:Name="rbUsor" Content="Ușor" IsChecked="True" GroupName="Dif" Margin="0,0,15,0"/>
                <RadioButton x:Name="rbMediu" Content="Mediu" GroupName="Dif" Margin="0,0,15,0"/>
                <RadioButton x:Name="rbGreu" Content="Greu" GroupName="Dif"/>
            </StackPanel>

            <Button Content="Salvează Întrebarea" Click="BtnSalveazaIntrebare_Click" Margin="0,20" Padding="10" Background="#C8E6C9" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel x:Name="pnlQuiz" Visibility="Collapsed">
            <Grid>
                <Button Content="← Abandon" Click="BtnBack_Click" HorizontalAlignment="Left" Margin="0,0,0,10" Background="Transparent"/>
                <Label x:Name="lblScorLive" Content="Scor: 0" HorizontalAlignment="Right" FontWeight="Bold" Foreground="Blue" FontSize="14"/>
            </Grid>

            <StackPanel x:Name="pnlNumeIntro">
                <Label Content="Introdu numele tău pentru a începe:" FontWeight="Bold" Foreground="DarkBlue"/>
                <TextBox x:Name="txtNumeUtilizator" Margin="0,5,0,15" Padding="8" FontSize="14"/>
                <Separator Margin="0,5"/>
            </StackPanel>

            <Label x:Name="lblId" FontSize="12" Foreground="Gray"/>
            <TextBlock x:Name="txtTextIntrebare" FontSize="18" TextWrapping="Wrap" Margin="0,10" FontWeight="SemiBold" MinHeight="40"/>
            <Label x:Name="lblDificultate" FontStyle="Italic" Foreground="#555"/>

            <Label Content="Răspunsul tău:" FontWeight="Bold" Margin="0,10,0,0"/>
            <StackPanel x:Name="pnlOptiuni">
                <CheckBox x:Name="chkA" Margin="0,5" FontSize="14"/>
                <CheckBox x:Name="chkB" Margin="0,5" FontSize="14"/>
                <CheckBox x:Name="chkC" Margin="0,5" FontSize="14"/>
            </StackPanel>

            <Button x:Name="btnNext" Content="Trimite Răspuns" Click="btnNext_Click" Margin="0,20" Padding="12" Background="#FFF9C4" FontWeight="Bold"/>
            <Label x:Name="lblFeedback" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel x:Name="pnlRezultate" Visibility="Collapsed">
            <Button Content="← Înapoi" Click="BtnBack_Click" HorizontalAlignment="Left" Margin="0,0,0,10" Background="Transparent"/>
            <Label Content="CLASAMENT GENERAL" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <ListBox x:Name="lstRezultate" Height="400" Margin="0,10"/>
        </StackPanel>

    </Grid>
</Window>